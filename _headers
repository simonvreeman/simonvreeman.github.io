# This is a comment
/*
    Content-Security-Policy: upgrade-insecure-requests
    Permissions-Policy: accelerometer=(), camera=(), geolocation=(), gyroscope=(), magnetometer=(), microphone=(), payment=(), usb=()
    X-DNS-Prefetch-Control: on
    X-John-Deere: 6320
    Link: <https://gtm.vreeman.com>; rel="preconnect"; crossorigin, <https://gtm.vreeman.com>; rel="dns-prefetch", <https://vreeman.com/schema.json>; rel="alternate"; type="application/ld+json"

# Prevent your pages.dev deployments showing in search results
https://:vreeman.pages.dev/*
    X-Robots-Tag: noindex

# EntityMap: served as application/json / text/html by default; just add caching
/entitymap.json
    Cache-Control: public, max-age=3600
/entitymap.html
    Cache-Control: public, max-age=3600

# ARDS capability catalog — needs the right Content-Type + CORS so agents can fetch cross-origin
/.well-known/ai-catalog.json
    Content-Type: application/ai-catalog+json
    Access-Control-Allow-Origin: *
    Cache-Control: public, max-age=3600
/.well-known/did.json
    Content-Type: application/did+json
    Access-Control-Allow-Origin: *
    Cache-Control: public, max-age=3600